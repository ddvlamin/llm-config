{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": [
    "google",
    "anthropic",
    "openai",
    "cortecs"
  ],
  "model": "google/gemini-3.5-flash",
  "default_agent": "dev",
  "provider": {
    "cortecs": {
      "models": {
        "deepseek-v4-flash": {
          "id": "deepseek-v4-flash",
          "name": "Deepseek V4 Flash"
        },
        "deepseek-v4-pro": {
          "id": "deepseek-v4-pro",
          "name": "Deepseek V4 Pro"
        },
        "devstral-2512": {
          "id": "devstral-2512",
          "name": "Devstral 2512"
        },
        "gemma-4-26b-a4b-it": {
          "id": "gemma-4-26b-a4b-it",
          "name": "Gemma 4 26b A4b It"
        },
        "glm-5": {
          "id": "zai.glm-5",
          "name": "Glm 5"
        },
        "kimi-k2.6": {
          "id": "kimi-k2.6",
          "name": "Kimi K2.6"
        },
        "mistral-medium-3.5": {
          "id": "mistral-medium-3.5",
          "name": "Mistral Medium 3.5"
        },
        "mistral-small-2603": {
          "id": "mistral-small-2603",
          "name": "Mistral Small 2603"
        },
        "qwen3.6-27b": {
          "id": "qwen3.6-27b",
          "name": "Qwen3.6 27b"
        },
        "qwen3.6-35b-a3b": {
          "id": "qwen3.6-35b-a3b",
          "name": "Qwen3.6 35b A3b"
        }
      },
      "options": {
        "baseURL": "https://llm.searchingpi.com/v1"
      },
      "whitelist": [
        "glm-5",
        "zai.glm-5",
        "kimi-k2.6",
        "deepseek-v4-pro",
        "deepseek-v4-flash",
        "gemma-4-26b-a4b-it",
        "qwen3.6-35b-a3b",
        "qwen3.6-27b",
        "mistral-medium-3.5",
        "devstral-2512",
        "mistral-small-2603"
      ]
    },
    "google": {
      "models": {
        "gemini-3.1-flash-lite": {
          "id": "gemini-3.1-flash-lite",
          "name": "Gemini 3.1 Flash Lite"
        },
        "gemini-3.5-flash": {
          "id": "gemini-3.5-flash",
          "name": "Gemini 3.5 Flash"
        }
      },
      "options": {
        "baseURL": "https://llm.searchingpi.com/v1beta"
      },
      "whitelist": [
        "gemini-3.1-flash-lite",
        "gemini-3.5-flash"
      ]
    }
  },
  "mcp": {
    "browser-use": {
      "type": "remote",
      "url": "https://api.browser-use.com/mcp",
      "headers": {
        "x-browser-use-api-key": "YOUR_BROWSER_USE_KEY_HERE"
      },
      "enabled": false
    },
    "browserbase": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@browserbasehq/mcp-server-browserbase"
      ],
      "env": {
        "BROWSERBASE_API_KEY": "YOUR_BROWSERBASE_KEY_HERE"
      },
      "enabled": false
    },
    "confluence": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "confluence-mcp-server"
      ],
      "env": {
        "CONFLUENCE_API_TOKEN": "YOUR_CONFLUENCE_TOKEN_HERE",
        "CONFLUENCE_BASE_URL": "YOUR_CONFLUENCE_URL_HERE",
        "CONFLUENCE_EMAIL": "YOUR_EMAIL_HERE"
      },
      "enabled": false
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    },
    "duckduckgo": {
      "type": "local",
      "command": [
        "web-search-mcp"
      ]
    },
    "evalview": {
      "type": "local",
      "command": [
        "python3",
        "-m",
        "evalview",
        "mcp",
        "serve"
      ],
      "env": {
        "OPENAI_API_KEY": "YOUR_OPENAI_API_KEY_HERE"
      },
      "enabled": false
    },
    "exa-web-search": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "exa-mcp-server"
      ],
      "env": {
        "EXA_API_KEY": "YOUR_EXA_API_KEY_HERE"
      },
      "enabled": false
    },
    "fetch": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-fetch",
        "--ignore-robots-txt"
      ]
    },
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/workspace/"
      ]
    },
    "firecrawl": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "firecrawl-mcp"
      ],
      "env": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_KEY}"
      }
    },
    "github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "jira": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-atlassian==0.21.0"
      ],
      "env": {
        "JIRA_API_TOKEN": "YOUR_JIRA_API_TOKEN_HERE",
        "JIRA_EMAIL": "YOUR_JIRA_EMAIL_HERE",
        "JIRA_URL": "YOUR_JIRA_URL_HERE"
      },
      "enabled": false
    },
    "magic": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@magicuidesign/mcp@latest"
      ]
    },
    "memory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "enabled": false
    },
    "omega-memory": {
      "type": "local",
      "command": [
        "/workspace/.venv/bin/omega",
        "serve"
      ]
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp",
        "--browser",
        "chrome"
      ],
      "enabled": false
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "supabase": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--project-ref=YOUR_PROJECT_REF"
      ],
      "enabled": false
    },
    "canva": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote@latest",
        "https://mcp.canva.com/mcp",
        "--auth-timeout",
        "60"
      ],
      "enabled": false
    }
  }
}